AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=YOUR_TEMP_SESSION_TOKEN
S3_BUCKET=atlas-scoring-frontend-2026

# -- SSH/rsync deploy (`npm run deploy`); uncomment to override defaults
# DEPLOY_SSH_USER=atlasdeploy
# DEPLOY_SSH_HOST=atlasscore.org
# DEPLOY_REMOTE_DIR=/ATLAS

# -- Telegram deploy notifications (optional; skipped if token unset)
# TELEGRAM_BOT_HTTP_API_TOKEN=
# Private channels (t.me/+invite) need a numeric id — invite URLs are not accepted by the Bot API:
# TELEGRAM_DEPLOY_CHAT_ID=-1001234567890
# Public channel username or numeric id (used when TELEGRAM_DEPLOY_CHAT_ID is unset):
# TELEGRAM_BOT_ATLAS_FRAMEWORK_DEVELOPMENT_NOTIFICATIONS_CHANNEL=@YourChannelName
# DEPLOY_TARGET=production
# DEPLOY_TARGET=staging
# TELEGRAM_NOTIFY_CHANNEL_KEY=development
# TELEGRAM_NOTIFY=false
TELEGRAM_BOT_ATLAS_FRAMEWORK_DEVELOPMENT_NOTIFICATIONS_CHANNEL=https://t.me/+fkpelrY4TC80N2I9
TELEGRAM_DEPLOY_CHAT_ID=-1003927878086